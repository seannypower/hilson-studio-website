---

<Layout title="Gear" description="The full gear list at The Hilson Studio: preamps, compressors, microphones, guitars, drums, amps, and more.">
  <section class="page-hero container">
    <h1>Gear</h1>
    <p class="lede">This is a big part of the sound of The Hilson Studio. These pieces have been specifically picked and tailored to provide a wide array of sounds and tones.</p>
  </section>

  <section class="block container">
    <img src="/images/gear-01.jpg" alt="Gear at The Hilson Studio" style="max-width: 700px; margin: 0 auto 2.5rem;" />
    <div class="gear-columns">
      {groups.map((g) => (
        <div class="gear-group">
          <h3>{g.title}</h3>
          <ul>
            {g.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Layout>
