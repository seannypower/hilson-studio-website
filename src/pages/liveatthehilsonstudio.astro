    <div class="splash-content">
      <img src="/images/lath-logo.png" alt="Live At The Hilson Studio" style="max-width: 320px; margin: 0 auto 1.5rem;" />
      <p>You just be ready to shine. We'll do the rest.</p>
      <a class="splash-cta" href="/liveatthehilson">Learn More</a>
    </div>
  </section>
</Layout>
