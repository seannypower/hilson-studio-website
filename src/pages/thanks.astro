---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You" description="Thanks for reaching out to The Hilson Studio.">
  <section class="block container prose center" style="padding: 5rem 1rem;">
    <h1>Thanks for reaching out!</h1>
    <p>We got your message and will get back to you shortly.</p>
    <p><a href="/about" class="splash-cta" style="color:var(--color-text); border-color:var(--color-text); display:inline-block; margin-top:1rem;">Back to the studio</a></p>
  </section>
</Layout>
