---
import Layout from '../layouts/Layout.astro';

const categories = [
  { title: 'Studio build', count: 52, thumb: '/images/space-16.jpg', href: '/space' },
  { title: 'acoustic vids', count: 40, thumb: '/images/artist-01.jpg', href: '/liveatthehilson' },
  { title: 'the space pics', count: 15, thumb: '/images/space-01.jpg', href: '/space' },
  { title: 'latth pics', count: 8, thumb: '/images/lath-splash-04.jpg', href: '/liveatthehilson' },
  { title: 'production vids', count: 13, thumb: '/images/videoprod-01.jpg', href: '/video-production' },
  { title: 'full band vids', count: 14, thumb: '/images/lath-01.jpg', href: '/liveatthehilson' },
  { title: 'laths looks', count: 11, thumb: '/images/lath-splash-01.jpg', href: '/liveatthehilson' },
];
---

<Layout title="Pics" description="Photo and video portfolio overview from The Hilson Studio.">
  <section class="stub-note container" style="margin-top:2rem;">
    Legacy portfolio index from the original site (not linked from the current nav). It originally linked to 7 separate sub-galleries (up to 52 items each) that weren't in the site's nav or sitemap — rather than rebuild all of those in full, each card here links to whichever already-built page covers that content most closely. Thumbnails are representative, not the exact originals.
  </section>

  <section class="page-hero container">
    <h1>Pics</h1>
  </section>

  <section class="block container">
    <div class="gallery-grid">
      {categories.map((c) => (
        <a href={c.href} class="lightbox-item" style="cursor:pointer;">
          <img src={c.thumb} alt={c.title} loading="lazy" />
          <span class="lightbox-item-caption">{c.title} &middot; {c.count} items</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
