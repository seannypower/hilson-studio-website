---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Video Shoot Booking" description="Book a Live At The Hilson Studio video shoot.">
  <section class="stub-note container" style="margin-top:2rem;">
    Legacy booking page from the original site (not linked from the current nav — the live "book a shoot" link now points to a Google Form instead). The coupon code below is from a past promotion; verify before reactivating.
  </section>

  <section class="page-hero container">
    <h1>Book a video shoot</h1>
    <p class="lede">Use coupon code "HOLIDAYS" to get $100 your shoot!</p>
  </section>

  <section class="block container">
    <div class="embed-wrap" style="max-width: 900px; margin: 0 auto; min-height: 700px;">
      <iframe
        src="https://app.acuityscheduling.com/schedule.php?owner=21216691&ref=sched_block"
        title="Book a video shoot"
        style="width:100%; height:800px; border:0;"
      ></iframe>
    </div>
  </section>
</Layout>
