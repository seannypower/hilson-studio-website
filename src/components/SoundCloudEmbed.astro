---
interface Props {
  url: string;
  title?: string;
}
const { url, title = 'SoundCloud playlist' } = Astro.props as Props;
---

<div class="soundcloud-embed">
  <iframe
    scrolling="no"
    frameborder="no"
    allow="autoplay"
    title={title}
    src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(url)}&color=ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false`}
  ></iframe>
</div>
